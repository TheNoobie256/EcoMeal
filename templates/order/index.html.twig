{% extends 'base.html.twig' %}
{% block title %}Orders{% endblock %}
{% block body %}
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="display-5 fw-bold text-dark mb-0">Orders</h1>
            <a href="{{ path('app_order_new') }}" class="btn btn-dark btn-lg rounded-pill shadow-sm fw-bold">
                + Create New Order
            </a>
        </div>

        <div class="table-container p-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-lime text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                    <tr>
                        <th class="ps-4 py-3 rounded-start">ID</th>
                        <th class="py-3">Package</th>
                        <th class="py-3">Consumer</th>
                        <th class="py-3">Date Ordered</th>
                        <th class="text-end pe-4 py-3 rounded-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody class="border-top-0">
                    {% for order in orders %}
                        <tr>
                            <td class="ps-4"><strong>{{ order.id }}</strong></td>
                            <td class="fw-bold"><span class="badge bg-secondary rounded-pill">{{ order.package.name }}</span></td>
                            <td>{{ order.consumer.firstName }} {{ order.consumer.lastName }}</td>
                            <td>{{ order.createdAt ? order.createdAt|date('M d, Y h:i A') : '' }}</td>
                            <td class="text-end pe-4">
                                <a href="{{ path('app_order_view', {id: order.id}) }}" class="btn btn-sm btn-outline-dark rounded-pill fw-bold px-3">View Details</a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
