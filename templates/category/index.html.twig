{% extends 'base.html.twig' %}
{% block title %}Categories{% endblock %}
{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }
    </style>
    <div class="example-wrapper">
        <a href="{{ path('app_category_new') }}">Create New Category</a>
        <br>
        <table>
            <thead>
            <tr>
                <th>id</th>
                <th>Name</th>
            </tr>
            </thead>
            <tbody>
            {% for category in categories %}
                <tr>
                    <td><a href="{{ path('app_category_view', {id: category.id}) }}">{{ category.id }}</a></td>
                    <td>{{ category.name }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
