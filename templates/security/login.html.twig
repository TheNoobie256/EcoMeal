{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="form-container overflow-hidden shadow-sm">

                    <div class="bg-lime p-4 text-center">
                        <h3 class="mb-0 fw-bold text-dark">Welcome Back</h3>
                    </div>

                    <div class="p-4 p-md-5">
                        <form method="post">
                            {% if error %}
                                <div class="alert alert-danger rounded-3 border-0 shadow-sm">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                            {% endif %}

                            {% if app.user %}
                                <div class="alert alert-info rounded-3 border-0 shadow-sm">
                                    You are logged in as {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}" class="fw-bold text-dark">Logout</a>
                                </div>
                            {% endif %}

                            <div class="mb-3">
                                <label for="username" class="form-label fw-bold text-secondary">Email</label>
                                <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control form-control-lg bg-light border-0" autocomplete="email" required autofocus>
                            </div>

                            <div class="mb-4">
                                <label for="password" class="form-label fw-bold text-secondary">Password</label>
                                <input type="password" name="_password" id="password" class="form-control form-control-lg bg-light border-0" autocomplete="current-password" required>
                            </div>

                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                            <div class="d-grid gap-2 mt-4">
                                <button class="btn btn-dark btn-lg rounded-pill shadow-sm fw-bold" type="submit">
                                    Sign In
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <p class="text-muted">Don't have an account? <a href="{{ path('app_register') }}" class="fw-bold text-dark">Register here</a></p>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
