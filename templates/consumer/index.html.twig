{% extends 'base.html.twig' %}
{% block title %}Consumers{% endblock %}
{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }
    </style>
    <div class="example-wrapper">
        <a href="{{ path('app_consumer_new') }}">Create New Consumer</a>
        <br>
        <table>
            <thead>
            <tr>
                <th>id</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Phone Number</th>
            </tr>
            </thead>
            <tbody>
            {% for consumer in consumers %}
                <tr>
                    <td><a href="{{ path('app_consumer_view', {id: consumer.id}) }}">{{ consumer.id }}</a></td>
                    <td>{{ consumer.firstName }}</td>
                    <td>{{ consumer.lastName }}</td>
                    <td>{{ consumer.phoneNumber }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
