{% extends 'base.html.twig' %}
{% block title %}View Consumer{% endblock %}
{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="detail-container overflow-hidden">
                    <div class="bg-lime p-4 d-flex justify-content-between align-items-center">
                        <h2 class="mb-0 fw-bold text-dark">{{ consumer.firstName }} {{ consumer.lastName }}</h2>
                        <span class="badge bg-dark rounded-pill fs-6">ID: {{ consumer.id }}</span>
                    </div>
                    <div class="p-0">
                        <ul class="list-group list-group-flush fs-5">
                            <li class="list-group-item p-4 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Phone Number</span>
                                <span class="text-end fw-bold">{{ consumer.phoneNumber }}</span>
                            </li>
                        </ul>
                    </div>
                    <div class="p-4 bg-light d-flex justify-content-between flex-wrap gap-2">
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_consumer') }}" class="btn btn-outline-secondary rounded-pill fw-bold px-4">← Back to Users List</a>
                        {% else %}
                            <a href="{{ path('app_package') }}" class="btn btn-outline-secondary rounded-pill fw-bold px-4">← Back to Packages</a>
                        {% endif %}
                        <div class="d-flex gap-2">
                            {% if not is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_consumer_edit', {id: consumer.id}) }}" class="btn btn-warning rounded-pill fw-bold px-4 shadow-sm">
                                    Edit
                                </a>
                            {% endif %}

                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_consumer_del', {id: consumer.id}) }}" class="btn btn-danger rounded-pill fw-bold px-4 shadow-sm">
                                    Delete User
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
