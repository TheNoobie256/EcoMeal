{% extends 'base.html.twig' %}
{% block title %}Businesses{% endblock %}
{% block body %}
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="display-5 fw-bold text-dark mb-0">Businesses</h1>
            <a href="{{ path('app_business_new') }}" class="btn btn-dark btn-lg rounded-pill shadow-sm fw-bold">
                + Create New Business
            </a>
        </div>

        <div class="table-container p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-lime text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                    <tr>
                        <th class="ps-4 py-3 rounded-start">ID</th>
                        <th class="py-3">Name</th>
                        <th class="py-3">City</th>
                        <th class="py-3">Street</th>
                        <th class="py-3">Type</th>
                        <th class="text-end pe-4 py-3 rounded-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody class="border-top-0">
                    {% for business in businesses %}
                        <tr>
                            <td class="ps-4"><strong>{{ business.id }}</strong></td>
                            <td class="fw-bold">{{ business.name }}</td>
                            <td>{{ business.city }}</td>
                            <td>{{ business.street }} {{ business.houseNumber }}</td>
                            <td><span class="badge bg-secondary rounded-pill">{{ business.businessType.name }}</span></td>
                            <td class="text-end pe-4">
                                <a href="{{ path('app_business_view', {id: business.id}) }}" class="btn btn-sm btn-outline-dark rounded-pill fw-bold px-3">View Details</a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
