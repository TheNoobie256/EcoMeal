{% extends 'base.html.twig' %}
{% block title %}View Business{% endblock %}
{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="detail-container overflow-hidden">
                    <div class="bg-lime p-4 d-flex justify-content-between align-items-center">
                        <h2 class="mb-0 fw-bold text-dark">{{ business.name }}</h2>
                        <span class="badge bg-dark rounded-pill fs-6">ID: {{ business.id }}</span>
                    </div>
                    <div class="p-0">
                        <ul class="list-group list-group-flush fs-5">
                            <li class="list-group-item p-4 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Location</span>
                                <span class="text-end">{{ business.city }}, {{ business.street }} {{ business.houseNumber }}</span>
                            </li>
                            <li class="list-group-item p-4 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Phone</span>
                                <span class="text-end">{{ business.phoneNumber }}</span>
                            </li>
                            <li class="list-group-item p-4 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Type</span>
                                <span class="badge bg-secondary rounded-pill">{{ business.businessType.name }}</span>
                            </li>
                        </ul>
                    </div>
                    <div class="p-4 bg-light d-flex justify-content-between flex-wrap gap-2">
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_business') }}" class="btn btn-outline-secondary rounded-pill fw-bold px-4">← Back to Businesses List</a>
                        {% else %}
                            <a href="{{ path('app_package') }}" class="btn btn-outline-secondary rounded-pill fw-bold px-4">← Back to Packages</a>
                        {% endif %}
                        <div class="d-flex gap-2">
                            <a href="{{ path('app_business_add_package', {id: business.id}) }}" class="btn btn-info rounded-pill fw-bold px-4 shadow-sm">Add Package</a>
                            <a href="{{ path('app_business_edit', {id: business.id}) }}" class="btn btn-warning rounded-pill fw-bold px-4 shadow-sm">Edit</a>
                            <a href="{{ path('app_business_del', {id: business.id}) }}" class="btn btn-danger rounded-pill fw-bold px-4 shadow-sm">Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
