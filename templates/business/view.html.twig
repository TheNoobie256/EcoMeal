{% extends 'base.html.twig' %}


{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        <p>{{ business.id }}</p>
        <p>{{ business.name }}</p>
        <p>{{ business.city }}</p>
        <p>{{ business.street }}</p>
        <p>{{ business.houseNumber }}</p>
        <p>{{ business.phoneNumber }}</p>
        <p>{{ business.businessType.name }}</p>

        <a href="{{ path('app_business') }}">Back</a>
        <a href="{{ path('app_business_del', {id:business.id}) }}">Delete</a>
        <a href="{{ path('app_business_edit', {id:business.id}) }}">Edit</a>
        <a href="{{ path('app_business_add_package', {id:business.id}) }}">Add package</a>
    </div>

{% endblock %}
