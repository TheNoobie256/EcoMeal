{% extends 'base.html.twig' %}

{% block title %}My Business Dashboard{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="display-5 fw-bold text-dark mb-0">📊 My Dashboard</h1>
            <a href="{{ path('app_package') }}" class="btn btn-outline-dark rounded-pill fw-bold px-4 shadow-sm">
                ← Back to Feed
            </a>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4 h-100 bg-lime">
                    <div class="card-body p-5 text-center">
                        <h5 class="text-uppercase fw-bold text-muted mb-3" style="letter-spacing: 1px;">
                            Packages Sold
                        </h5>
                        <h1 class="display-1 fw-bold text-dark mb-0">
                            {{ stats.packages_sold }}
                        </h1>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4 h-100 bg-light">
                    <div class="card-body p-5 text-center">
                        <h5 class="text-uppercase fw-bold text-muted mb-3" style="letter-spacing: 1px;">
                            Total Revenue
                        </h5>
                        <h1 class="display-1 fw-bold text-success mb-0">
                            ${{ stats.total_revenue|number_format(2) }}
                        </h1>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
