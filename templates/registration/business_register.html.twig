{% extends 'base.html.twig' %}
{% block title %}Register Business{% endblock %}
{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="form-container overflow-hidden">
                    <div class="bg-lime p-4">
                        <h3 class="mb-0 fw-bold text-dark">Register New Business</h3>
                    </div>
                    <div class="p-4 p-md-5">
                        {{ form_errors(registrationForm) }}
                        {{ form_start(registrationForm) }}
                        {{ form_row(registrationForm.email) }}
                        {{ form_row(registrationForm.plainPassword, { label: 'Password' }) }}

                        <hr class="my-4">
                        <h5 class="fw-bold mb-3">Business Details</h5>

                        {{ form_row(registrationForm.business.name) }}
                        <div class="row">
                            <div class="col-md-6">{{ form_row(registrationForm.business.city) }}</div>
                            <div class="col-md-6">{{ form_row(registrationForm.business.street) }}</div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">{{ form_row(registrationForm.business.houseNumber) }}</div>
                            <div class="col-md-6">{{ form_row(registrationForm.business.phoneNumber) }}</div>
                        </div>
                        {{ form_row(registrationForm.business.businessType) }}

                        <div class="d-grid gap-2 mt-4 pt-2">
                            <button type="submit" class="btn btn-dark btn-lg rounded-pill shadow-sm fw-bold w-100">
                                Register Business
                            </button>
                        </div>
                        {{ form_end(registrationForm) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
