{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="form-container overflow-hidden">
                    <div class="bg-lime p-4">
                        <h3 class="mb-0 fw-bold text-dark">Register as a Consumer</h3>
                    </div>
                    <div class="p-4 p-md-5">
                        {{ form_errors(registrationForm) }}
                        {{ form_start(registrationForm) }}

                        <h5 class="fw-bold mb-3 text-secondary">Account Details</h5>
                        {{ form_row(registrationForm.email) }}
                        {{ form_row(registrationForm.plainPassword, { label: 'Password' }) }}

                        <hr class="my-4">

                        <h5 class="fw-bold mb-3 text-secondary">Personal Information</h5>
                        <div class="row">
                            <div class="col-md-6">{{ form_row(registrationForm.consumer.firstName) }}</div>
                            <div class="col-md-6">{{ form_row(registrationForm.consumer.lastName) }}</div>
                        </div>
                        {{ form_row(registrationForm.consumer.phoneNumber) }}

                        <div class="mt-3 bg-light p-3 rounded-3 border">
                            {{ form_row(registrationForm.agreeTerms) }}
                        </div>

                        <div class="d-grid gap-2 mt-4 pt-2">
                            <button type="submit" class="btn btn-dark btn-lg rounded-pill shadow-sm fw-bold w-100">Create Account</button>
                        </div>

                        {{ form_end(registrationForm) }}
                    </div>
                </div>
                <div class="text-center mt-4">
                    <p class="text-muted">Already have an account? <a href="{{ path('app_login') }}" class="fw-bold text-dark">Log in here</a></p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
