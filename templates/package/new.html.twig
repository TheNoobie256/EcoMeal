{% extends 'base.html.twig' %}
{% block title %}New Package{% endblock %}
{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="form-container overflow-hidden">
                    <div class="bg-lime p-4">
                        <h3 class="mb-0 fw-bold text-dark">Add / Edit Package</h3>
                    </div>
                    <div class="p-4 p-md-5">
                        {{ form_start(form) }}
                        {{ form_row(form.name) }}
                        {{ form_row(form.description) }}

                        <div class="row">
                            <div class="col-md-6">{{ form_row(form.price) }}</div>
                            <div class="col-md-6">{{ form_row(form.category) }}</div>
                        </div>

                        {% if form.business is defined %}
                            {{ form_row(form.business) }}
                        {% endif %}

                        <div class="d-grid gap-2 mt-4 pt-2">
                            {{ form_row(form.submit, {'attr': {'class': 'btn btn-dark btn-lg rounded-pill shadow-sm fw-bold w-100'}}) }}
                            <a href="{{ path('app_package') }}" class="btn btn-light rounded-pill text-muted fw-bold">Cancel</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
