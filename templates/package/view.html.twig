{% extends 'base.html.twig' %}
{% block title %}View Package{% endblock %}
{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="detail-container overflow-hidden">

                    <div class="bg-lime p-4 d-flex justify-content-between align-items-center">
                        <h2 class="mb-0 fw-bold text-dark">{{ package.name }}</h2>

                        {% set current_hour = "now"|date("H") %}
                        {% set discount_active = current_hour >= 20 %}

                        <div>
                            {% if discount_active %}
                                <span class="badge bg-danger rounded-pill fs-6 me-2">-30% After 8 PM!</span>
                                <span class="text-muted text-decoration-line-through fs-5 me-2">${{ package.price }}</span>
                                <span class="badge bg-dark rounded-pill fs-4">${{ (package.price * 0.70)|number_format(2) }}</span>
                            {% else %}
                                <span class="badge bg-dark rounded-pill fs-5">${{ package.price }}</span>
                            {% endif %}
                        </div>
                    </div>

                    <div class="bg-light text-center border-bottom overflow-hidden" style="height: 300px;">
                        <img src="{{ asset('images/' ~ package.category.id ~ '.jpg') }}"
                             alt="{{ package.category.name }}"
                             class="img-fluid w-100 h-100"
                             style="object-fit: contain; background-color: #f4fcf4;">
                    </div>

                    <div class="p-0">
                        <ul class="list-group list-group-flush fs-5">
                            <li class="list-group-item p-4">
                                <span class="text-muted fw-bold d-block mb-1">Description</span>
                                <span>{{ package.description }}</span>
                            </li>
                            <li class="list-group-item p-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <span class="text-muted fw-bold">Business</span>

                                <div class="d-flex align-items-center gap-3">
                                    <span class="text-end fw-bold">{{ package.business.name }}</span>

                                    {% if is_granted('ROLE_CONSUMER') %}
                                        {% set isFavorite = app.user.consumer.favoriteBusinesses.contains(package.business) %}
                                        <form action="{{ path('app_consumer_favorite_business', {id: package.business.id}) }}" method="POST" class="m-0">
                                            <button type="submit" class="btn btn-sm {{ isFavorite ? 'btn-danger' : 'btn-outline-danger' }} rounded-pill fw-bold shadow-sm" style="padding: 4px 14px; font-size: 0.85rem;">
                                                {{ isFavorite ? '❤️ Favorited' : '🤍 Favorite' }}
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </li>
                            <li class="list-group-item p-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <span class="text-muted fw-bold">Location</span>

                                <div class="d-flex align-items-center gap-3">
                                    <span class="text-end">{{ package.business.street }} {{ package.business.houseNumber }}, {{ package.business.city }}</span>

                                    {% set address_string = package.business.street ~ ' ' ~ package.business.houseNumber ~ ', ' ~ package.business.city %}
                                    {% set map_query = address_string|url_encode %}

                                    <a href="https://www.google.com/maps/search/?api=1&query={{ map_query }}"
                                       target="_blank"
                                       class="btn btn-sm btn-outline-primary rounded-pill fw-bold shadow-sm"
                                       style="padding: 4px 14px; font-size: 0.85rem;">
                                        📍 Get Directions
                                    </a>
                                </div>
                            </li>
                            <li class="list-group-item p-4 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Category</span>
                                <span class="badge bg-secondary rounded-pill">{{ package.category.name }}</span>
                            </li>
                        </ul>
                    </div>

                    <div class="p-4 bg-light d-flex justify-content-between flex-wrap gap-2">

                        {# LEFT SIDE: Back and Order Buttons #}
                        <div class="d-flex gap-2">
                            <a href="{{ path('app_package') }}" class="btn btn-outline-secondary rounded-pill fw-bold px-4">← Back</a>

                            {% if is_granted('ROLE_CONSUMER') %}
                                {% if isAvailable %}
                                    <form action="{{ path('app_package_order_direct', {id: package.id}) }}" method="POST" onsubmit="return confirm('Are you sure you want to order this package?');">
                                        <button type="submit" class="btn btn-dark rounded-pill fw-bold px-4 shadow-sm">
                                            🛒 Order Now
                                        </button>
                                    </form>
                                {% else %}
                                    <button class="btn btn-secondary rounded-pill fw-bold px-4 shadow-sm" disabled>
                                        🚫 Sold Out
                                    </button>
                                {% endif %}
                            {% endif %}
                        </div>

                        {# RIGHT SIDE: Admin/Business Actions #}
                        <div class="d-flex gap-2">
                            {% if app.user and app.user.business and app.user.business.id == package.business.id %}
                                <a href="{{ path('app_package_edit', {id: package.id}) }}" class="btn btn-warning rounded-pill fw-bold px-4 shadow-sm">Edit</a>
                            {% endif %}

                            {% if is_granted('ROLE_ADMIN') or (app.user and app.user.business and app.user.business.id == package.business.id) %}
                                <a href="{{ path('app_package_del', {id: package.id}) }}" class="btn btn-danger rounded-pill fw-bold px-4 shadow-sm">Delete</a>
                            {% endif %}
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
