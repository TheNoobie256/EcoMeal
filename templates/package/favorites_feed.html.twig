{% if packages is empty %}
    <div class="alert alert-light border rounded-4 text-center py-5 shadow-sm">
        <h4 class="fw-bold text-secondary mb-3">No packages here yet!</h4>
        <p class="text-muted mb-4">You haven't favorited any businesses, or your favorite stores are sold out right now.</p>
        <a href="{{ path('app_package') }}" class="btn btn-dark rounded-pill fw-bold px-4">Browse All Packages</a>
    </div>
{% else %}
    <div class="table-container overflow-hidden shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-lime text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                <tr>
                    <th class="ps-4 py-3 rounded-start">Package</th>
                    <th class="py-3">Business</th>
                    <th class="py-3">Category</th>
                    <th class="py-3">Price</th>
                    <th class="text-end pe-4 py-3 rounded-end">Action</th>
                </tr>
                </thead>
                <tbody class="border-top-0">
                {% for package in packages %}
                    <tr>
                        <td class="ps-4 fw-bold">{{ package.name }}</td>
                        <td><span class="badge bg-danger rounded-pill">{{ package.business.name }}</span></td>
                        <td class="fw-bold">{{ package.category.name }}</td>
                        <td>
                            {% set current_hour = "now"|date("H") %}
                            {% if current_hour >= 20 %}
                                <span class="text-muted text-decoration-line-through small">${{ package.price }}</span><br>
                                <span class="text-danger fw-bold">${{ (package.price * 0.70)|number_format(2) }}</span>
                            {% else %}
                                ${{ package.price }}
                            {% endif %}
                        </td>
                        <td class="text-end pe-4">
                            <a href="{{ path('app_package_view', {id: package.id}) }}" class="btn btn-sm btn-outline-dark rounded-pill fw-bold px-3">
                                View Details
                            </a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}
